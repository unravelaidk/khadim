{
  "name": "khadim",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun -r --if-present build",
    "dev": "bun --filter @khadim/web dev",
    "sandbox:dev": "bun --filter @khadim/firecracker-sandbox dev",
    "sandbox:check": "bun --filter @khadim/firecracker-sandbox check",
    "docs:dev": "bun --filter @khadim/docs dev",
    "docs:build": "bun --filter @khadim/docs build",
    "desktop:dev": "bun --filter @khadim/desktop tauri dev",
    "desktop:build": "bun --filter @khadim/desktop build",
    "plugins:build": "bun --filter '@khadim/plugin-*' build",
    "start": "bun --filter @khadim/web start",
    "typecheck": "bun --filter @khadim/web typecheck",
    "test": "bun -r --if-present test",
    "db:generate": "bun --filter @khadim/web db:generate",
    "db:migrate": "bun --filter @khadim/web db:migrate"
  },
  "workspaces": [
    "apps/*",
    "apps/desktop/plugins/*",
    "packages/*"
  ]
}
