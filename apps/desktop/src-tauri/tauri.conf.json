{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Khadim Desktop",
  "version": "0.5.0",
  "identifier": "com.khadim.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Khadim Desktop",
        "width": 1320,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Unravel AI",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.comodoca.com"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
