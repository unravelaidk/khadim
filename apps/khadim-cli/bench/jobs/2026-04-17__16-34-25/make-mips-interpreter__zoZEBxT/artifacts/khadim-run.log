183: void DG_SleepMs(uint32_t ms)
184: {
185:     // Spinloop implementation for sleep using inline assembly
186:     // Assuming 3GHz processor (3 billion cycles per second)
187:     // 1ms = 3 million cycles
188:     uint64_t cycles_per_ms = 3;
189:     uint64_t total_cycles = cycles_per_ms * ms;
190:     
191:     volatile uint64_t i;
192:     for (i = 0; i < total_cycles; i++)
193:     {
194:         // Use volatile inline assembly to ensure the loop isn't optimized away
195:         __asm__ volatile("" ::: "memory");
196:     }
197: }
