340: // Helper function to split a path into directory and filename
341: void split_path(const char* path, char* dir_path, char* filename) {
342:     const char* last_slash = strrchr(path, '/');
343:     
344:     if (last_slash == NULL) {
345:         // No directory part
346:         strcpy(dir_path, ".");
347:         strcpy(filename, path);
348:     } else if (last_slash == path) {
349:         // Root directory
350:         strcpy(dir_path, "/");
351:         strcpy(filename, last_slash + 1);
352:     } else {
353:         // Extract directory path and filename
354:         size_t dir_len = last_slash - path;
355:         strncpy(dir_path, path, dir_len);
356:         dir_path[dir_len] = '\0';
357:         strcpy(filename, last_slash + 1);
358:     }
359: }
