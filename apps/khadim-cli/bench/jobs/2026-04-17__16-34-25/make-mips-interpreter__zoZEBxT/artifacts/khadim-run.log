571: // SYS_unlink: Delete a file
572: int sys_unlink(const char* pathname) {
573:     if (root == NULL) {
574:         init_filesystem();
575:     }
576:     
577:     // Cannot unlink root
578:     if (strcmp(pathname, "/") == 0) {
579:         return -EBUSY;
580:     }
581:     
582:     FileNode* parent_dir = NULL;
583:     FileNode* node = find_node(pathname, &parent_dir);
584:     
585:     if (node == NULL) {
586:         return -ENOENT; // File doesn't exist
587:     }
588:     
589:     if (node->type == FILE_TYPE_DIRECTORY && node->num_entries > 0) {
590:         return -ENOTEMPTY; // Directory not empty
591:     }
592:     
593:     // Check if the file is open
594:     for (int i = 0; i < MAX_FILE_DESCRIPTORS; i++) {
595:         if (fd_table[i].used && fd_table[i].node == node) {
596:             return -EBUSY; // File is open
597:         }
598:     }
599:     
600:     // Remove from parent directory
601:     for (size_t i = 0; i < parent_dir->num_entries; i++) {
602:         if (parent_dir->entries[i].node == node) {
603:             // Remove this entry by shifting all entries after it
604:             for (size_t j = i; j < parent_dir->num_entries - 1; j++) {
605:                 parent_dir->entries[j] = parent_dir->entries[j + 1];
606:             }
607:             parent_dir->num_entries--;
608:             parent_dir->modified = time(NULL);
609:             break;
610:         }
611:     }
612:     
613:     // Free the node's resources
614:     if (node->type == FILE_TYPE_REGULAR) {
615:         if (node->data != NULL) {
616:             free(node->data);
617:         }
618:     } else {
619:         if (node->entries != NULL) {
620:             free(node->entries);
621:         }
622:     }
623:     
624:     free(node);
625:     
626:     return 0;
627: }
