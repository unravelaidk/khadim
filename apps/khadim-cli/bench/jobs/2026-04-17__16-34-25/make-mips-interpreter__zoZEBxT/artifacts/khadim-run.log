87:         
88:         /* Output parameter */
89:         : "=r" (result)
90:         
91:         /* Input parameters */
92:         : "r" (syscall_num),
93:           "r" (arg1),
94:           "r" (arg2),
95:           "r" (arg3),
96:           "r" (arg4),
97:           "r" (arg5),
98:           "r" (arg6)
