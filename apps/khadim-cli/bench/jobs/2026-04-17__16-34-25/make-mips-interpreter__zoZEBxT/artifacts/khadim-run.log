79: static void addKeyToQueue(int pressed, unsigned int keyCode)
80: {
81:     unsigned char key = convertToDoomKey(keyCode);
82: 
83:     unsigned short keyData = (pressed << 8) | key;
84: 
85:     s_KeyQueue[s_KeyQueueWriteIndex] = keyData;
86:     s_KeyQueueWriteIndex++;
87:     s_KeyQueueWriteIndex %= KEYQUEUE_SIZE;
88: }
