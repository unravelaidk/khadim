sltu at, zero, a1  # at = (0 < 0) ? 1 : 0 = 0
addiu t3, at, 1089  # t3 = 0 + 1089 = 1089 = 0x441
li t4, 2           # t4 = 2
li t5, 420         # t5 = 420 = 0644
li t2, 0           # t2 = 0
