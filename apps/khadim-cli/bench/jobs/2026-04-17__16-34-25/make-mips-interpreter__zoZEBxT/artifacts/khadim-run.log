39: static unsigned char convertToDoomKey(unsigned int key)
40: {
41:     switch (key)
42:     {
43:     case '\r':  // Return key
44:         key = KEY_ENTER;
45:         break;
46:     case 27:    // Escape key
47:         key = KEY_ESCAPE;
48:         break;
49:     case 0x4B:  // Left arrow
50:         key = KEY_LEFTARROW;
51:         break;
52:     case 0x4D:  // Right arrow
53:         key = KEY_RIGHTARROW;
54:         break;
55:     case 0x48:  // Up arrow
56:         key = KEY_UPARROW;
57:         break;
58:     case 0x50:  // Down arrow
59:         key = KEY_DOWNARROW;
60:         break;
61:     case 0x1D:  // Ctrl
62:         key = KEY_FIRE;
63:         break;
64:     case ' ':   // Space
65:         key = KEY_USE;
66:         break;
67:     case 0x2A:  // Left Shift
68:     case 0x36:  // Right Shift
69:         key = KEY_RSHIFT;
70:         break;
71:     default:
72:         key = (key);
73:         break;
74:     }
75: 
76:     return key;
77: }
