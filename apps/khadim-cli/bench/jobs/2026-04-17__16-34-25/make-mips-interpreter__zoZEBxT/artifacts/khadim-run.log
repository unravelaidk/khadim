202: // Helper function to find a file node by path
203: FileNode* find_node(const char* path, FileNode** parent_dir) {
204:     if (root == NULL) {
205:         init_filesystem();
206:     }
207:     
208:     // Handle empty or root path
209:     if (path == NULL || path[0] == '\0' || strcmp(path, "/") == 0) {
210:         if (parent_dir) *parent_dir = NULL;
211:         return root;
212:     }
213:     
214:     // Make a copy of the path to tokenize
215:     char path_copy[MAX_PATH_LENGTH];
216:     strncpy(path_copy, path, MAX_PATH_LENGTH);
217:     path_copy[MAX_PATH_LENGTH - 1] = '\0';
218:     
219:     // Start at root
220:     FileNode* current = root;
221:     FileNode* parent = NULL;
222:     
223:     // Handle absolute path
224:     char* token = strtok(path_copy, "/");
225:     if (path[0] == '/') {
226:         // Path starts with /, so we start at the root
227:         current = root;
228:     }
229:     
230:     // Traverse the path
231:     while (token != NULL) {
232:         if (current->type != FILE_TYPE_DIRECTORY) {
233:             return NULL; // Not a directory
234:         }
235:         
236:         parent = current;
237:         current = NULL;
238:         
239:         // Look for the token in the current directory
240:         for (size_t i = 0; i < parent->num_entries; i++) {
241:             if (strcmp(parent->entries[i].name, token) == 0) {
242:                 current = parent->entries[i].node;
243:                 break;
244:             }
245:         }
246:         
247:         if (current == NULL) {
248:             // Not found
249:             if (parent_dir) *parent_dir = parent;
250:             return NULL;
251:         }
252:         
253:         token = strtok(NULL, "/");
254:     }
255:     
256:     if (parent_dir) *parent_dir = parent;
257:     return current;
258: }
