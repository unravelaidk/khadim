629: // SYS_rename: Rename a file
630: int sys_rename(const char* oldpath, const char* newpath) {
631:     if (root == NULL) {
632:         init_filesystem();
633:     }
634:     
635:     FileNode* old_parent = NULL;
636:     FileNode* node = find_node(oldpath, &old_parent);
637:     
638:     if (node == NULL) {
639:         return -ENOENT; // Old path doesn't exist
640:     }
641:     
642:     // Cannot rename root
643:     if (node == root) {
644:         return -EBUSY;
645:     }
646:     
647:     // Check if the new path already exists
648:     FileNode* new_parent = NULL;
649:     FileNode* existing = find_node(newpath, &new_parent);
650:     
651:     if (existing != NULL) {
652:         // If the target exists and is a directory, it must be empty
653:         if (existing->type == FILE_TYPE_DIRECTORY) {
654:             if (existing->num_entries > 0) {
655:                 return -ENOTEMPTY;
656:             }
657:             
658:             // Remove the existing directory
659:             int result = sys_unlink(newpath);
660:             if (result < 0) {
661:                 return result;
662:             }
663:         } else {
664:             // Remove the existing file
665:             int result = sys_unlink(newpath);
666:             if (result < 0) {
667:                 return result;
668:             }
669:         }
670:     }
671:     
672:     // Get the new parent directory and filename
673:     char new_dir_path[MAX_PATH_LENGTH];
674:     char new_filename[MAX_PATH_LENGTH];
675:     
676:     split_path(newpath, new_dir_path, new_filename);
677:     
678:     if (strlen(new_filename) == 0) {
679:         return -EINVAL; // Invalid new filename
680:     }
681:     
682:     if (new_parent == NULL) {
683:         new_parent = find_node(new_dir_path, NULL);
684:         if (new_parent == NULL) {
685:             return -ENOENT; // New parent directory not found
686:         }
687:     }
688:     
689:     if (new_parent->type != FILE_TYPE_DIRECTORY) {
690:         return -ENOTDIR;
691:     }
692:     
693:     // Remove from old parent
694:     for (size_t i = 0; i < old_parent->num_entries; i++) {
695:         if (old_parent->entries[i].node == node) {
696:             // Remove this entry by shifting all entries after it
697:             for (size_t j = i; j < old_parent->num_entries - 1; j++) {
698:                 old_parent->entries[j] = old_parent->entries[j + 1];
699:             }
700:             old_parent->num_entries--;
701:             break;
702:         }
703:     }
704:     
705:     // Update node name
706:     strncpy(node->name, new_filename, MAX_PATH_LENGTH);
707:     node->name[MAX_PATH_LENGTH - 1] = '\0';
708:     node->parent = new_parent;
709:     
710:     // Add to new parent
711:     int result = add_to_directory(new_parent, new_filename, node);
712:     if (result < 0) {
713:         // This is a serious error, we've already removed it from the old parent
714:         // In a real filesystem, we'd need to handle this more gracefully
715:         return result;
716:     }
717:     
718:     old_parent->modified = time(NULL);
719:     new_parent->modified = time(NULL);
720:     
721:     return 0;
722: }
