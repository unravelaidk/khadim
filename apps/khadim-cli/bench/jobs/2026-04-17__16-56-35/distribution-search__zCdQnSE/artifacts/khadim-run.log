```python
import numpy as np
from scipy import optimize

N = 150000

def compute_kl(p_vec, N):
    """Compute forward and backward KL divergences."""
    u = np.ones(N) / N
    
    # Forward KL: KL(P||U) = Σ P(i) * log(P(i) / U(i))
    # = Σ P(i) * log(P(i) * N)
    # = Σ P(i) * (log(P(i)) + log(N))
    # = log(N) + Σ P(i) * log(P(i))
    # = log(N) - H(P)
    
    # Avoid log(0)
    p_safe = np.maximum(p_vec, 1e-300)
    forward_kl = np.sum(p_vec * np.log(p_safe * N))
    
    # Backward KL: KL(U||P) = Σ U(i) * log(U(i) / P(i))
    # = (1/N) * Σ log(1/(N*P(i)))
    # = -(1/N) * Σ log(N*P(i))
    backward_kl = -np.sum(np.log(N * p_safe)) / N
    
    return forward_kl, backward_kl

# Two-level distribution approach
# k tokens with probability a, (N-k) tokens with probability b
# k*a + (N-k)*b = 1
# KL(P||U) = 10
# KL(U||P) = 10

def objective(params):
    log_k, log_alpha = params
    k = np.exp(log_k)
    alpha = np.exp(log_alpha)
    
    p = k / N  # fraction of high-prob tokens
    beta = (1 - p * alpha) / (1 - p) if p < 1 else 1.0
    
    if beta <= 0 or alpha <= 0:
        return 1e10
    
    # Forward KL
    fkl = p * alpha * np.log(alpha) + (1-p) * beta * np.log(beta)
    
    # Backward KL
    bkl = -(p * np.log(alpha) + (1-p) * np.log(beta))
    
    return (fkl - 10.0)**2 + (bkl - 10.0)**2

# Initial guess based on our analysis
# k ≈ 7, alpha ≈ 22026
result = optimize.minimize(objective, [np.log(7), np.log(22000)], method='Nelder-Mead')
log_k, log_alpha = result.x
k_float = np.exp(log_k)
alpha = np.exp(log_alpha)
p = k_float / N
beta = (1 - p * alpha) / (1 - p)

print(f"k_float = {k_float}, alpha = {alpha}, beta = {beta}")
print(f"p = {p}")

# Now create the actual distribution
k = int(round(k_float))
a = alpha / N
b = beta / N

# Adjust to ensure normalization
# k*a + (N-k)*b = 1
# We need to adjust a or b to ensure exact normalization
# Let's adjust b: b = (1 - k*a) / (N-k)
b = (1 - k * a) / (N - k)

p_vec = np.full(N, b)
p_vec[:k] = a

# Verify
fkl, bkl = compute_kl(p_vec, N)
print(f"Forward KL: {fkl}")
print(f"Backward KL: {bkl}")
print(f"Sum: {np.sum(p_vec)}")

# Check if within tolerance
if abs(fkl - 10.0) <= 0.001 and abs(bkl - 10.0) <= 0.001:
    np.save('/app/dist.npy', p_vec)
    print("Saved distribution!")
else:
    print("Not within tolerance, need to adjust...")
```

