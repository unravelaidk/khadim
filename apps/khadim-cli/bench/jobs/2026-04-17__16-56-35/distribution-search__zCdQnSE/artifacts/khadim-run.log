```python
import numpy as np
from scipy.optimize import minimize_scalar, minimize

N = 150000

def compute_kls_two_level(p0):
    """Compute forward and backward KL for a two-level distribution."""
    p2 = (1 - p0) / (N - 1)
    if p2 <= 0:
        return None, None
    
    # Forward KL = KL(P||U)
    forward_kl = p0 * np.log(p0 * N) + (1 - p0) * np.log(p2 * N)
    
    # Backward KL = KL(U||P)
    backward_kl = -np.log(N) - (np.log(p0) + (N - 1) * np.log(p2)) / N
    
    return forward_kl, backward_kl

# Scan p0 values
for p0 in [0.01, 0.1, 0.5, 0.9, 0.95, 0.99, 0.999, 0.9999]:
    fwd, bwd = compute_kls_two_level(p0)
    print(f"p0={p0}: forward={fwd:.4f}, backward={bwd:.4f}")
```

