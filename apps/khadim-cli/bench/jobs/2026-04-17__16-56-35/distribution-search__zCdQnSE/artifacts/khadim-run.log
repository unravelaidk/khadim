```python
import numpy as np
from scipy.optimize import fsolve, minimize_scalar, minimize

N = 150000

def compute_kl_two_level(k, a, N):
    """Compute KL divergences for two-level distribution."""
    b = (1 - k * a) / (N - k)
    if b <= 0 or a <= 0:
        return None, None
    
    alpha = N * a
    beta = N * b
    
    fkl = k * a * np.log(alpha) + (N - k) * b * np.log(beta)
    bkl = -(k / N) * np.log(alpha) - ((N - k) / N) * np.log(beta)
    
    return fkl, bkl

# Approach 1: Two-level distribution, try different k values
best_result = None
best_error = float('inf')

for k in range(1, 100):
    # For each k, find a that minimizes (fkl-10)^2 + (bkl-10)^2
    def objective(log_a):
        a = np.exp(log_a)
        fkl, bkl = compute_kl_two_level(k, a, N)
        if fkl is None:
            return 1e10
        return (fkl - 10.0)**2 + (bkl - 10.0)**2
    
    # Find reasonable bounds for a
    # a must be positive and k*a < 1
    a_max = (1 - 1e-10) / k
    a_min = 1e-15
    
    result = minimize_scalar(objective, bounds=(np.log(a_min), np.log(a_max)), method='bounded')
    a = np.exp(result.x)
    fkl, bkl = compute_kl_two_level(k, a, N)
    
    error = max(abs(fkl - 10), abs(bkl - 10)) if fkl is not None else float('inf')
    
    if error < best_error:
        best_error = error
        best_result = (k, a, fkl, bkl)

k, a, fkl, bkl = best_result
print(f"Best two-level: k={k}, a={a}")
print(f"Forward KL = {fkl}, Backward KL = {bkl}")
print(f"|Forward KL - 10| = {abs(fkl - 10)}")
print(f"|Backward KL - 10| = {abs(bkl - 10)}")
```

