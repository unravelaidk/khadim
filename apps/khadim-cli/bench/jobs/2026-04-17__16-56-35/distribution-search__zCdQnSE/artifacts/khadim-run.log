import numpy as np
from scipy.optimize import fsolve, minimize_scalar

N = 150000

# Step 1: Solve for continuous parameters
def equations(params):
    p, alpha = params
    if p <= 0 or p >= 1 or alpha <= 0:
        return [1e10, 1e10]
    beta = (1 - p * alpha) / (1 - p)
    if beta <= 0:
        return [1e10, 1e10]
    
    fkl = p * alpha * np.log(alpha) + (1-p) * beta * np.log(beta)
    bkl = -(p * np.log(alpha) + (1-p) * np.log(beta))
    
    return [fkl - 10.0, bkl - 10.0]

# Initial guess
p0 = 7.0 / N
alpha0 = 22000.0

sol = fsolve(equations, [p0, alpha0], full_output=True)
p_cont, alpha_cont = sol[0]
beta_cont = (1 - p_cont * alpha_cont) / (1 - p_cont)

print(f"Continuous solution: p = {p_cont}, alpha = {alpha_cont}, beta = {beta_cont}")
print(f"k_float = {p_cont * N}")

# Step 2: Round k and create distribution
k = int(round(p_cont * N))
print(f"k = {k}")

# Step 3: For this k, find a that best satisfies both constraints
# b = (1 - k*a) / (N - k)
# Forward KL = k*a*log(N*a) + (N-k)*b*log(N*b)
# Backward KL = -(k/N)*log(N*a) - ((N-k)/N)*log(N*b)

def kl_divergences(a):
    if a <= 0 or a >= 1:
        return 1e10, 1e10
    b = (1 - k * a) / (N - k)
    if b <= 0:
        return 1e10, 1e10
    
    alpha = N * a
    beta_val = N * b
    
    fkl = k * a * np.log(alpha) + (N - k) * b * np.log(beta_val)
    bkl = -(k / N) * np.log(alpha) - ((N - k) / N) * np.log(beta_val)
    
    return fkl, bkl

def objective(a):
    fkl, bkl = kl_divergences(a)
    return (fkl - 10.0)**2 + (bkl - 10.0)**2

# Initial guess for a
a_init = alpha_cont / N
result = minimize_scalar(objective, bounds=(1e-10, 1 - 1e-10), method='bounded')
a_opt = result.x
b_opt = (1 - k * a_opt) / (N - k)

fkl, bkl = kl_divergences(a_opt)
print(f"Optimal a = {a_opt}, b = {b_opt}")
print(f"Forward KL = {fkl}, Backward KL = {bkl}")
print(f"|Forward KL - 10| = {abs(fkl - 10)}")
print(f"|Backward KL - 10| = {abs(bkl - 10)}")
