```python
import numpy as np
from scipy.optimize import minimize

N = 150000

def compute_kl(params):
    # params: [log_p0, log_p1, n1_ratio]
    # p0: probability of token 0
    # p1: probability of each of n1 tokens
    # p2: probability of remaining tokens (determined by normalization)
    
    log_p0, log_p1, n1_ratio = params
    p0 = np.exp(log_p0)
    p1 = np.exp(log_p1)
    n1 = int(n1_ratio * (N - 1))
    n1 = max(1, min(n1, N - 2))
    
    p2 = (1 - p0 - n1 * p1) / (N - 1 - n1)
    
    if p2 <= 0 or p2 >= 1 or p0 <= 0 or p0 >= 1 or p1 <= 0 or p1 >= 1:
        return 1e10
    
    # Forward KL: KL(P||U) = -H(P) + log(N)
    entropy = -p0 * np.log(p0) - n1 * p1 * np.log(p1) - (N - 1 - n1) * p2 * np.log(p2)
    forward_kl = -entropy + np.log(N)
    
    # Backward KL: KL(U||P) = -log(N) - (1/N) * sum(log(P(i)))
    avg_log_p = (np.log(p0) + n1 * np.log(p1) + (N - 1 - n1) * np.log(p2)) / N
    backward_kl = -np.log(N) - avg_log_p
    
    target = 10.0
    
    return (forward_kl - target)**2 + (backward_kl - target)**2

# Initial guess
x0 = [np.log(0.5), np.log(1e-5), 0.01]

result = minimize(compute_kl, x0, method='Nelder-Mead', options={'maxiter': 100000, 'xatol': 1e-12, 'fatol': 1e-12})
