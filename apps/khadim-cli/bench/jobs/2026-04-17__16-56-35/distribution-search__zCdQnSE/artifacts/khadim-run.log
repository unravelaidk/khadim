import numpy as np
from scipy.optimize import fsolve, minimize

N = 150000

def solve_continuous():
    """Solve for continuous parameters of two-level distribution."""
    def eqs(params):
        p, log_alpha = params
        alpha = np.exp(log_alpha)
        if p <= 0 or p >= 1:
            return [1e10, 1e10]
        beta = (1 - p * alpha) / (1 - p)
        if beta <= 0:
            return [1e10, 1e10]
        
        fkl = p * alpha * np.log(alpha) + (1-p) * beta * np.log(beta)
        bkl = -(p * np.log(alpha) + (1-p) * np.log(beta))
        
        return [fkl - 10.0, bkl - 10.0]
    
    # Initial guess
    p0 = 7.0 / N
    log_alpha0 = np.log(22000.0)
    
    sol = fsolve(eqs, [p0, log_alpha0], full_output=True)
    p, log_alpha = sol[0]
    alpha = np.exp(log_alpha)
    beta = (1 - p * alpha) / (1 - p)
    
    return p, alpha, beta

p, alpha, beta = solve_continuous()
print(f"Continuous: p={p}, alpha={alpha}, beta={beta}")
print(f"k_float = {p * N}")

# Try different values of k near the continuous solution
k_float = p * N
best_k = None
best_error = float('inf')

for k in range(max(1, int(k_float) - 5), int(k_float) + 6):
    # For each k, find a that minimizes the sum of squared KL errors
    # b = (1 - k*a) / (N - k)
    
    def objective(log_a):
        a = np.exp(log_a)
        if a <= 0 or a >= 1:
            return 1e10
        b = (1 - k * a) / (N - k)
        if b <= 0:
            return 1e10
        
        alpha_val = N * a
        beta_val = N * b
        
        fkl = k * a * np.log(alpha_val) + (N - k) * b * np.log(beta_val)
        bkl = -(k / N) * np.log(alpha_val) - ((N - k) / N) * np.log(beta_val)
        
        return (fkl - 10.0)**2 + (bkl - 10.0)**2
    
    from scipy.optimize import minimize_scalar
    result = minimize_scalar(objective, bounds=(np.log(1e-10), np.log(0.5)), method='bounded')
    error = result.fun
    if error < best_error:
        best_error = error
        best_k = k
        best_a = np.exp(result.x)

print(f"Best k = {best_k}, best error = {best_error}")

# Create distribution with best k and a
k = best_k
a = best_a
b = (1 - k * a) / (N - k)

p_vec = np.full(N, b)
p_vec[:k] = a

# Verify
u = np.ones(N) / N
p_safe = np.maximum(p_vec, 1e-300)
forward_kl = np.sum(p_vec * np.log(p_safe / u))
backward_kl = np.sum(u * np.log(u / p_safe))

print(f"Sum = {np.sum(p_vec)}")
print(f"Forward KL = {forward_kl}")
print(f"Backward KL = {backward_kl}")
print(f"|Forward KL - 10| = {abs(forward_kl - 10)}")
print(f"|Backward KL - 10| = {abs(backward_kl - 10)}")

if abs(forward_kl - 10) <= 0.001 and abs(backward_kl - 10) <= 0.001:
    np.save('/app/dist.npy', p_vec)
    print("Saved!")
else:
    print("Not within tolerance, need more sophisticated approach")
