```python
import numpy as np
from scipy.optimize import minimize, differential_evolution

N = 150000
target_kl = 10.0
tol = 0.001

def make_distribution(params):
    """Create a three-level distribution."""
    log_a, log_b, n1 = params
    a = np.exp(log_a)
    b = np.exp(log_b)
    n1 = int(round(n1))
    n1 = max(1, min(n1, N - 2))
    
    c = (1 - a - n1 * b) / (N - 1 - n1)
    
    if c <= 0 or c >= 1 or a <= 0 or a >= 1 or b <= 0 or b >= 1:
        return None
    
    return a, b, c, n1

def compute_kls(a, b, c, n1):
    """Compute forward and backward KL divergences."""
    n2 = N - 1 - n1
    
    # Forward KL = KL(P||U) = Σ P(i) * log(P(i) / U(i))
    # = Σ P(i) * (log(P(i)) + log(N))
    # = -H(P) + log(N)
    entropy = -a * np.log(a) - n1 * b * np.log(b) - n2 * c * np.log(c)
    forward_kl = -entropy + np.log(N)
    
    # Backward KL = KL(U||P) = Σ U(i) * log(U(i) / P(i))
    # = -log(N) - (1/N) * Σ log(P(i))
    avg_log_p = (np.log(a) + n1 * np.log(b) + n2 * np.log(c)) / N
    backward_kl = -np.log(N) - avg_log_p
    
    return forward_kl, backward_kl

def objective(params):
    result = make_distribution(params)
    if result is None:
        return 1e10
    a, b, c, n1 = result
    fwd, bwd = compute_kls(a, b, c, n1)
    return (fwd - target_kl)**2 + (bwd - target_kl)**2

# Try different initial guesses
best_result = None
best_score = float('inf')

for a_init in [0.5, 0.8, 0.9, 0.95, 0.99]:
    for b_init in [1e-4, 1e-5, 1e-6, 1e-7, 1e-8]:
        for n1_init in [10, 100, 1000, 10000]:
            x0 = [np.log(a_init), np.log(b_init), n1_init]
            try:
                result = minimize(objective, x0, method='Nelder-Mead', 
                                options={'maxiter': 10000, 'xatol': 1e-15, 'fatol': 1e-15})
                if result.fun < best_score:
                    best_score = result.fun
                    best_result = result
            except:
                pass

print(f"Best score: {best_score}")
print(f"Best params: {best_result.x}")

# Extract the distribution
a, b, c, n1 = make_distribution(best_result.x)
fwd, bwd = compute_kls(a, b, c, n1)
print(f"Forward KL: {fwd}")
print(f"Backward KL: {bwd}")

# Create the full distribution
dist = np.zeros(N)
dist[0] = a
dist[1:1+n1] = b
dist[1+n1:] = c

# Verify
print(f"Sum: {dist.sum()}")
print(f"Min: {dist.min()}")
print(f"Max: {dist.max()}")

# Save
np.save('/app/dist.npy', dist)
```

