```python
import cv2
import numpy as np
import toml

def analyze_video(video_path):
    cap = cv2.VideoCapture(video_path)
    
    # Read the first frame as the background
    ret, first_frame = cap.read()
    if not ret:
        raise ValueError("Could not read the first frame")
    
    first_gray = cv2.cvtColor(first_frame, cv2.COLOR_BGR2GRAY)
    h, w = first_gray.shape
    
    # Process each frame
    max_y_list = []
    
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        diff = cv2.absdiff(first_gray, gray)
        
        # Threshold
        _, mask = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)
        
        # Find the max y-coordinate of the foreground pixels
        coords = np.where(mask > 0)
        if len(coords[0]) > 100:  # Need enough pixels
            max_y = coords[0].max()
        else:
            max_y = None
        
        max_y_list.append(max_y)
    
    cap.release()
    
    # Find the ground level
    # Use the median max_y from the first 30 frames where the runner is visible
    ground_candidates = [v for v in max_y_list[:30] if v is not None]
    if len(ground_candidates) > 0:
        ground_level = np.median(ground_candidates)
    else:
        ground_level = h  # Default to the bottom of the frame
    
    # Detect takeoff: first frame where max_y drops below ground_level - threshold
    threshold = 15
    takeoff_frame = None
    for i, v in enumerate(max_y_list):
        if v is not None and v < ground_level - threshold:
            takeoff_frame = i + 1  # +1 because frame 0 is the background
            break
    
    # Detect landing: first frame after takeoff where max_y returns to ground_level - threshold
    landing_frame = None
    if takeoff_frame is not None:
        for i in range(takeoff_frame, len(max_y_list)):
            v = max_y_list[i]
            if v is not None and v >= ground_level - threshold:
                landing_frame = i + 1  # +1 because frame 0 is the background
                break
    
    return takeoff_frame, landing_frame

# Analyze the example video
takeoff, landing = analyze_video('/app/example_video.mp4')
print(f'Takeoff frame: {takeoff}')
print(f'Landing frame: {landing}')

# Write the output TOML file
output = {
    'jump_takeoff_frame_number': takeoff,
    'jump_land_frame_number': landing
}

with open('/app/output.toml', 'w') as f:
    toml.dump(output, f)
```

