```python
import cv2
import numpy as np
import toml

def analyze_video(video_path):
    cap = cv2.VideoCapture(video_path)
    
    # Read the first frame as the background
    ret, first_frame = cap.read()
    if not ret:
        raise ValueError("Could not read the first frame")
    
    first_gray = cv2.cvtColor(first_frame, cv2.COLOR_BGR2GRAY)
    
    # Process each frame
    max_y_values = []
    frame_count = 0
    
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        diff = cv2.absdiff(first_gray, gray)
        
        # Threshold
        _, mask = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)
        
        # Find the max y-coordinate of the foreground pixels
        coords = np.where(mask > 0)
        if len(coords[0]) > 100:  # Need enough pixels
            max_y = coords[0].max()
        else:
            max_y = None
        
        max_y_values.append(max_y)
        frame_count += 1
    
    cap.release()
    
    # Smooth the max_y values
    # Replace None values with the nearest non-None value
    smoothed = []
    for i, v in enumerate(max_y_values):
        if v is not None:
            smoothed.append(v)
        else:
            # Find the nearest non-None value
            left = right = None
            for j in range(i-1, -1, -1):
                if max_y_values[j] is not None:
                    left = max_y_values[j]
                    break
            for j in range(i+1, len(max_y_values)):
                if max_y_values[j] is not None:
                    right = max_y_values[j]
                    break
            if left is not None and right is not None:
                smoothed.append((left + right) / 2)
            elif left is not None:
                smoothed.append(left)
            elif right is not None:
                smoothed.append(right)
            else:
                smoothed.append(0)
    
    # Estimate the ground level
    # Use the median max_y from the first 30 frames where the runner is visible
    ground_level_candidates = [v for v in max_y_values[:30] if v is not None]
    if len(ground_level_candidates) > 0:
        ground_level = np.median(ground_level_candidates)
    else:
        ground_level = 520  # Default
    
    # Detect takeoff: first frame where max_y drops below (ground_level - threshold)
    threshold = 15
    takeoff_frame = None
    for i, v in enumerate(max_y_values):
        if v is not None and v < ground_level - threshold:
            takeoff_frame = i + 1  # +1 because frame 0 is the background
            break
    
    # Detect landing: first frame after takeoff where max_y returns to (ground_level - threshold)
    landing_frame = None
    if takeoff_frame is not None:
        for i in range(takeoff_frame, len(max_y_values)):
            v = max_y_values[i]
            if v is not None and v >= ground_level - threshold:
                landing_frame = i + 1  # +1 because frame 0 is the background
                break
    
    return takeoff_frame, landing_frame
```

