{
  "targets": {
    "debug": {
      "outFile": "build/debug.wasm",
      "textFile": "build/debug.wat",
      "debug": true,
      "optimizeLevel": 0,
      "shrinkLevel": 0
    },
    "release": {
      "outFile": "build/release.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 2,
      "noAssert": true
    }
  },
  "options": {
    "runtime": "stub",
    "exportStart": false,
    "use": "abort="
  }
}
